# PatchGuard - Environment Configuration

# ------------------------------------------------------------------------------
# PostgreSQL Database
# ------------------------------------------------------------------------------
POSTGRES_USER=patchmgr
POSTGRES_PASSWORD=patchmgr_secret_password_here
POSTGRES_DB=patchmgr
# Dev connection string (Postgres running on localhost:5432)
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ------------------------------------------------------------------------------
# Redis & Celery
# ------------------------------------------------------------------------------
REDIS_PASSWORD=patchguard_redis_pass_dev
CELERY_BROKER_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1

# ------------------------------------------------------------------------------
# Authentication (JWT)
# ------------------------------------------------------------------------------
JWT_SECRET_KEY=dev_secret_key_change_in_prod
JWT_ACCESS_LIFETIME_MINUTES=30
JWT_REFRESH_LIFETIME_DAYS=7

# ------------------------------------------------------------------------------
# Django Backend
# ------------------------------------------------------------------------------
DJANGO_SECRET_KEY=django-insecure-dev-key
DJANGO_ENV=dev
DJANGO_LOG_LEVEL=INFO
ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=*
